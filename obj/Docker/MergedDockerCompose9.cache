name: dockercompose4290244327010687009
services:
  trade.api:
    build:
      context: D:\projects\TradeAPI
      dockerfile: API/Dockerfile
    container_name: trade.api
    depends_on:
      trade.database:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "5000"
      ASPNETCORE_HTTPS_PORTS: "5001"
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5000
        published: "5000"
        protocol: tcp
      - mode: ingress
        target: 5001
        published: "5001"
        protocol: tcp
      - mode: ingress
        target: 5000
        protocol: tcp
      - mode: ingress
        target: 5001
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\vkunr\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\vkunr\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
  trade.database:
    container_name: trade.database
    environment:
      POSTGRES_DB: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_USER: tradedb
    image: postgres:13
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    volumes:
      - type: volume
        source: trade_db_data
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: dockercompose4290244327010687009_default
volumes:
  trade_db_data:
    name: dockercompose4290244327010687009_trade_db_data